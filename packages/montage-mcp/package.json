{
  "name": "@wanteddev/montage-ios-mcp",
  "version": "0.3.0",
  "description": "Model Context Protocol server for the Montage iOS Design System (Wanted Lab)",
  "type": "module",
  "license": "MIT",
  "author": "Wanted Lab",
  "homepage": "https://github.com/wanteddev/montage-ios",
  "repository": {
    "type": "git",
    "url": "https://github.com/wanteddev/montage-ios.git",
    "directory": "packages/montage-mcp"
  },
  "bin": {
    "montage-ios-mcp": "./bin/montage-mcp.js"
  },
  "files": [
    "bin/**/*",
    "dist/**/*",
    "data/**/*",
    "README.md",
    "README.ko.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsdown",
    "start:http": "node dist/http.js",
    "start:stdio": "node dist/stdio.js",
    "dev:http": "tsx watch src/http.ts",
    "dev:stdio": "tsx src/stdio.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "express": "^4.21.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.10",
    "tsdown": "^0.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
